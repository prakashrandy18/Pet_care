---
import PageLayout from '../layouts/PageLayout.astro'
import AuthForm from '../components/portal/AuthForm'
import { pageSEO } from '../config/seo'

// If already logged in, the React component will redirect to /portal/dashboard
---

<PageLayout
  title="Customer Login - Ps Pet Care"
  description="Log in to your PS Pet Care customer portal to manage bookings and pet profiles."
  noindex={true}
>
  <div class="min-h-[80vh] flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-gray-950">
    <div class="max-w-md w-full space-y-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4 shadow-sm">
          🐾
        </div>
        <h2 class="mt-6 text-3xl font-display font-bold text-gray-900 dark:text-white">
          Welcome Back
        </h2>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
          Or <a href="/register" class="font-medium text-primary-600 hover:text-primary-500 transition-colors">create a new account</a>
        </p>
      </div>

      <AuthForm client:only="react" type="login" />
      
    </div>
  </div>
</PageLayout>
